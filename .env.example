# Postgres connection string (Railway provides this automatically as DATABASE_URL
# when you add a Postgres database to your project)
DATABASE_URL=postgres://user:password@localhost:5432/well_collective

# Generate with: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:loretta@lorettabates.com

# Comma-separated list of allowed origins for CORS (your deployed app URL(s))
ALLOWED_ORIGINS=http://localhost:5173

# Timezone used for the Monday 7am / daily 7am schedule
SCHEDULE_TIMEZONE=America/New_York

# Shared secret the admin app must send to manage content schedule / trigger test sends
ADMIN_API_KEY=change-me

# Your WordPress site URL (used for member login + membership status checks)
WORDPRESS_URL=https://lorettabates.com

# Shared secret sent to the well/v1/membership-status endpoint on WordPress.
# Must match the WELL_API_KEY constant defined in the WordPress Code Snippet.
WELL_API_KEY=change-me

# WooCommerce REST API credentials (WP Admin -> WooCommerce -> Settings ->
# Advanced -> REST API -> Add Key, with Read/Write permissions).
# Used to create real store coupons from the bulk coupon generator.
WC_STORE_URL=https://lorettabates.com
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

# Anthropic API key (https://console.anthropic.com) used to generate the daily
# motivation boost, recipe, and nutrition tip automatically each morning.
ANTHROPIC_API_KEY=

PORT=4000
