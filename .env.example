# Postgres connection string (Railway provides this automatically as DATABASE_URL
# when you add a Postgres database to your project)
DATABASE_URL=postgres://user:password@localhost:5432/well_collective

# Generate with: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:loretta@lorettabates.com

# Comma-separated list of allowed origins for CORS (your deployed app URL(s))
ALLOWED_ORIGINS=http://localhost:5173

# Timezone used for the Monday 7am / daily 7am schedule
SCHEDULE_TIMEZONE=America/New_York

# Shared secret the admin app must send to manage content schedule / trigger test sends
ADMIN_API_KEY=change-me

PORT=4000
